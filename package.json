{
  "name": "popover-trail",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dnd": {
      "types": "./dist/dnd.d.ts",
      "import": "./dist/dnd.js",
      "require": "./dist/dnd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsup",
    "lint": "oxlint",
    "format": "oxfmt --write src",
    "preview": "vite preview",
    "test": "vitest run"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-focus-lock": "^2.13.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.20",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "knip": "^6.26.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-focus-lock": "^2.13.7",
    "tsup": "^8.5.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  }
}
