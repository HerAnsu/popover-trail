{
  "name": "popover-trail",
  "version": "1.0.0",
  "description": "Headless React 19 library for managing cascading popover paths, draggable floating windows, and async data hydration.",
  "keywords": [
    "react",
    "react-19",
    "popover",
    "popovers",
    "popover-trail",
    "cascading-popover",
    "floating-ui",
    "floating-window",
    "tooltip",
    "dropdown",
    "menu",
    "headless",
    "headless-ui",
    "unstyled",
    "compound-components",
    "draggable",
    "drag-and-drop",
    "dnd",
    "dnd-kit",
    "zustand",
    "web-workers",
    "web-worker",
    "async-hydration",
    "ui-components",
    "react-components"
  ],
  "author": "Ansu <kstenind@gmail.com>",
  "license": "MIT",
  "homepage": "https://github.com/HerAnsu/popover-trail#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/HerAnsu/popover-trail.git"
  },
  "bugs": {
    "url": "https://github.com/HerAnsu/popover-trail/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./dnd": {
      "types": "./dist/dnd.d.ts",
      "import": "./dist/dnd.js",
      "require": "./dist/dnd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:lib": "tsup && tsc -p tsconfig.lib.json --emitDeclarationOnly --outDir dist",
    "lint": "oxlint",
    "format": "oxfmt --write src",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "prepublishOnly": "npm run build:lib && npm test",
    "knip": "knip"
  },
  "dependencies": {
    "fast-deep-equal": "^3.1.3"
  },
  "peerDependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.20",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-focus-lock": "^2.13.7",
    "zustand": "^5.0.14"
  },
  "peerDependenciesMeta": {
    "@dnd-kit/core": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@dnd-kit/core": "^6.3.1",
    "@floating-ui/react": "^0.27.20",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "clsx": "^2.1.1",
    "knip": "^6.26.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.71.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-focus-lock": "^2.13.7",
    "tsup": "^8.5.1",
    "typescript": "^7.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10",
    "zustand": "^5.0.14"
  }
}
