{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 100,
  "tabWidth": 2,
  "useTabs": false,
  "semi": true,
  "singleQuote": true,
  "bracketSpacing": true,
  "bracketSameLine": true,
  "arrowParens": "always",
  "trailingComma": "all",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "experimentalSortPackageJson": true,
  "embeddedLanguageFormatting": "auto",
  "ignorePatterns": [
    "node_modules/**",
    "dist/**",
    "package-lock.json",
    "pnpm-lock.yaml"
  ]
}